{
  "name": "nayepankh-vims",
  "version": "1.0.0",
  "description": "Volunteer Information Management System for NayePankh Foundation",
  "main": "server.js",
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix frontend",
    "backend-install": "npm install --prefix backend",
    "frontend-install": "npm install --prefix frontend",
    "server": "npm run dev --prefix backend",
    "client": "npm run dev --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "keywords": [
    "volunteer",
    "ngo",
    "management",
    "react",
    "express",
    "mongodb"
  ],
  "author": "NayePankh Foundation",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
